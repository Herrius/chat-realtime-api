// Prisma schema — B3 Chat Realtime API
// Generador clásico (prisma-client-js) → se importa como `@prisma/client`.
// Flujo: `prisma migrate dev` en local, `prisma migrate deploy` en prod.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Los modelos se agregan slice por slice:
//   M1 → User · M2 → Room, Membership · M3 → Message · M5 → ReadReceipt

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String
  password  String // hash bcrypt, nunca el plano
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  createdRooms Room[]       @relation("RoomCreator")
  memberships  Membership[]

  @@map("users")
}

model Room {
  id          String   @id @default(uuid())
  name        String   @unique
  isPrivate   Boolean  @default(false)
  createdById String
  createdBy   User     @relation("RoomCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  memberships Membership[]

  @@map("rooms")
}

// Relación N:M usuario↔sala, materializada para guardar metadatos (joinedAt) y
// ser la unidad de autorización (¿este usuario pertenece a esta sala?).
model Membership {
  id       String   @id @default(uuid())
  userId   String
  roomId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([userId, roomId]) // un usuario no se une dos veces a la misma sala
  @@index([roomId])
  @@map("memberships")
}
