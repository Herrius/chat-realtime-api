NODE_ENV=development
PORT=3000
# Apunta a los servicios del docker-compose expuestos en el host.
DATABASE_URL="postgresql://chat:chat@localhost:5432/chat?schema=public"
REDIS_URL="redis://localhost:6379"
# Secreto HS256 (mín. 16 chars). En prod usar uno largo y aleatorio.
JWT_SECRET="dev-secret-change-me-please-32-characters"
JWT_EXPIRES_IN="1d"
CORS_ORIGIN="*"
